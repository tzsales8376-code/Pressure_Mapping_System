<Window x:Class="PressureMappingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PressureMappingSystem.Controls"
        xmlns:vm="clr-namespace:PressureMappingSystem.ViewModels"
        Title="{Binding L[App.Title]}"
        Width="1500" Height="960"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app.ico"
        Background="#FF1E1E2E"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="BrandOrange" Color="#FFED7D31"/>
        <SolidColorBrush x:Key="BrandBlue" Color="#FF2B5797"/>
        <SolidColorBrush x:Key="BrandDarkBlue" Color="#FF1B3A5C"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FF252536"/>
        <SolidColorBrush x:Key="SurfaceBg" Color="#FF2D2D40"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE0E0E8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9898A8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFE53935"/>

        <Style x:Key="BrandBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- IconBtn: 圖示按鈕的特化樣式（Padding 較小、適合放 18x18 SVG）-->
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource BrandBtn}">
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style x:Key="IconToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RecordBtn" TargetType="Button" BasedOn="{StaticResource BrandBtn}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="ToolBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandDarkBlue}" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Resources/app.ico" Width="28" Height="28" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="TRANZX" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandOrange}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding L[App.Subtitle]}" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="4,0,0,2"/>
                    <TextBlock Text="{Binding L[App.Version]}" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                </StackPanel>

                <!-- Language + Device Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DetectedDeviceInfo}" Foreground="{StaticResource AccentGreen}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding L[UI.Language]}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="120" SelectedIndex="0" SelectionChanged="LanguageCombo_SelectionChanged" FontSize="11">
                        <ComboBoxItem Content="繁體中文"/>
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="日本語"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" Padding="6,4">
            <WrapPanel>
                <!-- Connection -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="{Binding L[UI.COM]}" VerticalAlignment="Center" Margin="4,0"/>
                    <ComboBox Width="85" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" Margin="2,0"/>
                    <Button Content="&#x27F3;" FontSize="14" Style="{StaticResource IconBtn}"
                            Command="{Binding ScanDevicesCommand}"
                            ToolTip="{Binding L[Toolbar.Refresh]}"/>
                    <Button Content="{Binding L[UI.Connect]}" Style="{StaticResource BrandBtn}" Command="{Binding ConnectCommand}"/>
                    <Button Content="{Binding L[UI.Disconnect]}" Style="{StaticResource BrandBtn}" Command="{Binding DisconnectCommand}"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Measurement Control -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <Button Content="{Binding L[UI.StartMeasure]}" Style="{StaticResource BrandBtn}" Command="{Binding StartMeasurementCommand}" Background="{StaticResource AccentGreen}" FontWeight="Bold"/>
                    <Button Content="{Binding L[UI.StopMeasure]}" Style="{StaticResource BrandBtn}" Command="{Binding StopMeasurementCommand}" Background="{StaticResource AccentRed}" FontWeight="Bold"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Simulation -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <ComboBox Width="105" SelectedIndex="1" Margin="2,0" SelectionChanged="SimModeCombo_SelectionChanged" FontSize="12">
                        <ComboBoxItem Content="{Binding L[SimMode.StaticCenter]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.MovingPressure]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.PulsingPressure]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.MultiPoint]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.FullSurface]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.RandomNoise]}"/>
                    </ComboBox>
                    <Button Content="&#x25B6;" FontSize="14" Style="{StaticResource IconBtn}"
                            Command="{Binding StartSimulationCommand}"
                            ToolTip="{Binding L[UI.StartSim]}"/>
                    <Button Content="&#x25A0;" FontSize="14" Style="{StaticResource IconBtn}"
                            Command="{Binding StopSimulationCommand}"
                            ToolTip="{Binding L[UI.StopSim]}"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Zero + Calibration + Settings -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <ToggleButton Content="&#x2300;" FontSize="16"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding IsZeroEnabled}"
                                  ToolTip="{Binding L[UI.Zero]}"/>
                    <ComboBox Width="130" Margin="4,0,2,0"
                              ItemsSource="{Binding AvailableCalProfiles}"
                              SelectedItem="{Binding SelectedCalProfile}"
                              DisplayMemberPath="Name"
                              ToolTip="{Binding L[Toolbar.CalRecipe]}"
                              FontSize="12"/>
                    <Button Content="&#x2696;" FontSize="16"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding OpenCalibrationCommand}"
                            ToolTip="{Binding L[UI.Calibration]}"/>
                    <Button Content="&#x2699;" FontSize="16"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="{Binding L[UI.Settings]}"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- View Toggles (圖表選擇按鈕已移除—重複功能，使用熱力圖區左上的 TabControl 切換)  -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <!-- 2D 熱圖/等高線切換 (DisplayMode 切換，原 SetHeatmap/SetContourCommand 整合) -->
                    <ToggleButton Content="∿" FontSize="16"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowContourMode, Mode=TwoWay}"
                                  ToolTip="{Binding L[UI.2DContour]}"/>
                    <ToggleButton Content="&#x25B2;" FontSize="13"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowPeakMap}"
                                  ToolTip="{Binding L[UI.Peak]}"/>
                    <ToggleButton Content="&#x229E;" FontSize="14"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowGrid}"
                                  ToolTip="{Binding L[UI.Grid]}"/>
                    <ToggleButton Content="123" FontSize="11"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowValues}"
                                  ToolTip="{Binding L[UI.Values]}"/>
                    <ToggleButton Content="&#x2295;" FontSize="14"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowCoP}"
                                  ToolTip="{Binding L[UI.CoPLabel]}"/>
                    <ToggleButton Content="&#x25B0;" FontSize="13"
                                  Style="{StaticResource IconToggleBtn}"
                                  IsChecked="{Binding ShowLegend}"
                                  ToolTip="{Binding L[UI.Legend]}"/>
                    <Border Width="1" Background="#33FFFFFF" Margin="6,2"/>

                    <!-- ROI 畫框 (按需求保留畫框能力，按鈕從右側 ROI panel 移到此處) -->
                    <Button Content="&#x25AD;" FontSize="14"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding AddRoiRectCommand}"
                            ToolTip="{Binding L[Btn.Rect]}"/>
                    <Button Content="&#x25EF;" FontSize="14"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding AddRoiEllipseCommand}"
                            ToolTip="{Binding L[Btn.Ellipse]}"/>
                    <Button Content="&#x2716;" FontSize="13"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding ClearRoiCommand}"
                            ToolTip="{Binding L[Btn.Clear]}"/>

                    <!-- Interpolation Level -->
                    <Border Width="1" Background="#33FFFFFF" Margin="6,2"/>
                    <TextBlock Text="{Binding L[UI.Interp]}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="4,0,2,0"/>
                    <ComboBox x:Name="InterpCombo" Width="80" SelectedIndex="0" SelectionChanged="InterpCombo_SelectionChanged" FontSize="12" VerticalAlignment="Center">
                        <ComboBoxItem Content="1×1"/>
                        <ComboBoxItem Content="3×3"/>
                        <ComboBoxItem Content="5×5"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Visualization Tabs -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" x:Name="ViewTabControl" SelectedIndex="{Binding SelectedViewTab}"
                            Background="{StaticResource SurfaceBg}" BorderBrush="#33FFFFFF">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
                            <Setter Property="Padding" Value="12,6"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- Tab 0: 2D Heatmap -->
                    <TabItem Header="{Binding L[Tab.Heatmap]}">
                        <controls:HeatmapControl x:Name="HeatmapView"
                            PressureData="{Binding CurrentPressureData}"
                            FrameInfo="{Binding CurrentFrame}"
                            DisplayMode="{Binding DisplayMode}"
                            ShowGrid="{Binding ShowGrid}"
                            ShowValues="{Binding ShowValues}"
                            ShowCoP="{Binding ShowCoP}"
                            ShowLegend="{Binding ShowLegend}"
                            ContourLevels="{Binding ContourLevels}"
                            ColorScaleMax="{Binding ColorScaleMaxGrams}"
                            IsPaused="{Binding IsFrozen}"
                            InterpolationLevel="{Binding InterpolationLevel}"/>
                    </TabItem>

                    <!-- Tab 1: 3D Surface -->
                    <TabItem Header="{Binding L[Tab.3DSurface]}">
                        <controls:Surface3DControl x:Name="Surface3DView"
                            PressureData="{Binding CurrentPressureData}"
                            ColorScaleMax="{Binding ColorScaleMaxGrams}"/>
                    </TabItem>

                    <!-- Tab 2: Trend Chart -->
                    <TabItem Header="{Binding L[Tab.TrendChart]}">
                        <controls:TrendChartControl x:Name="TrendChartView"/>
                    </TabItem>
                </TabControl>

                <!-- Status Bar (錄製/暫停/擷取按鈕已移到右側 panel；此處僅保留 FPS 與幀數資訊) -->
                <Border Grid.Row="1" Background="{StaticResource PanelBg}" CornerRadius="4" Margin="2" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AccentGreen}" FontSize="13">
                            <Run Text="FPS: "/>
                            <Run Text="{Binding CurrentFps, StringFormat=F1, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ RIGHT PANEL ═══ -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4">

                    <!-- Statistics panel removed (重複資訊—使用熱力圖區內嵌統計面板) -->

                    <!-- PEAK 峰值追蹤 (單點 session 最大值；品管記錄重要指標) -->
                    <GroupBox Header="{Binding L[Panel.Peak]}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="18" Margin="2">
                                <Run Text="{Binding SessionPeakPressure, StringFormat=F1, Mode=OneWay}"/><Run Text=" g"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="2">
                                <Run Text="@Row "/><Run Text="{Binding SessionPeakRow, Mode=OneWay}"/>
                                <Run Text=" Col "/><Run Text="{Binding SessionPeakCol, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Content="{Binding L[Btn.Reset]}" Style="{StaticResource BrandBtn}"
                                    Command="{Binding ResetPeakCommand}" Padding="10,5" Margin="2,4,2,0"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ROI Analysis panel removed (按需求保留畫框能力但不顯示分析面板) -->

                    <!-- Comparison -->
                    <GroupBox Header="比對分析 / Comparison">
                        <StackPanel>
                            <!-- 模式說明 -->
                            <Border Background="#FF2D2D40" Padding="6,4" Margin="2,2,2,4"
                                    BorderBrush="#FFED7D31" BorderThickness="1" CornerRadius="2">
                                <TextBlock Text="模式：基準-待測 (Reference vs DUT)"
                                           Foreground="#FFED7D31" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- A / B 摘要 -->
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#FFED7D31" BorderThickness="1"
                                        Margin="2,0,1,0" Padding="4,3" CornerRadius="2">
                                    <StackPanel>
                                        <TextBlock Text="A" FontWeight="Bold" Foreground="{StaticResource BrandOrange}" FontSize="11"/>
                                        <TextBlock Text="{Binding SnapshotASummary, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#FFED7D31" BorderThickness="1"
                                        Margin="1,0,2,0" Padding="4,3" CornerRadius="2">
                                    <StackPanel>
                                        <TextBlock Text="B" FontWeight="Bold" Foreground="{StaticResource BrandOrange}" FontSize="11"/>
                                        <TextBlock Text="{Binding SnapshotBSummary, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- 凍結畫面（從左下方搬移過來的 Pause 按鈕） + 設為 A / B 按鈕 -->
                            <TextBlock Text="1. 先按「凍結」鎖住畫面，2. 再按「設為 A」或「設為 B」"
                                       Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       Margin="2,4,2,2" TextWrapping="Wrap"/>
                            <ToggleButton Content="❄ 凍結畫面"
                                          Style="{StaticResource ToolBtn}"
                                          IsChecked="{Binding IsFrozen}"
                                          ToolTip="{Binding L[UI.Freeze]}"
                                          HorizontalAlignment="Stretch"
                                          Padding="10,5" Margin="2,2"
                                          FontWeight="Bold"/>
                            <WrapPanel>
                                <Button Content="設為 A" Style="{StaticResource BrandBtn}"
                                        Command="{Binding SetSnapshotACommand}" Padding="10,4"/>
                                <Button Content="設為 B" Style="{StaticResource BrandBtn}"
                                        Command="{Binding SetSnapshotBCommand}" Padding="10,4"/>
                                <Button Content="清除" Style="{StaticResource BrandBtn}"
                                        Command="{Binding ClearSnapshotsCommand}" Padding="10,4"/>
                            </WrapPanel>

                            <!-- 展開比對視窗 -->
                            <Button Content="📊 展開比對視窗"
                                    Style="{StaticResource BrandBtn}"
                                    Command="{Binding OpenComparisonWindowCommand}"
                                    IsEnabled="{Binding HasBothSnapshots}"
                                    HorizontalAlignment="Stretch"
                                    Margin="2,6,2,2" Padding="10,5"
                                    FontWeight="Bold"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Export -->
                    <GroupBox Header="{Binding L[Panel.Export]}">
                        <WrapPanel>
                            <Button Content="{Binding L[Btn.CSV]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportCsvCommand}" Width="60"/>
                            <Button Content="{Binding L[Btn.JPG]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportJpgCommand}" Width="60"/>
                            <Button Content="{Binding L[Btn.PDFReport]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportPdfCommand}" Width="90"/>
                            <Button Content="{Binding L[Btn.CalReport]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportCalReportCommand}" Width="90"/>
                            <Button Content="{Binding L[Btn.OpenFolder]}" Style="{StaticResource BrandBtn}" Command="{Binding OpenExportFolderCommand}" Width="110" Margin="2"/>
                        </WrapPanel>
                    </GroupBox>

                    <!-- Session Management（含錄製按鈕：原左下方搬移過來） -->
                    <GroupBox Header="{Binding L[Panel.Recording]}">
                        <StackPanel>
                            <!-- 錄製控制（原左下方搬移過來） -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="{Binding L[UI.Record]}"
                                        Style="{StaticResource RecordBtn}"
                                        Command="{Binding StartRecordingCommand}"
                                        FontWeight="Bold" Padding="10,5"/>
                                <Button Content="⏹"
                                        Style="{StaticResource BrandBtn}"
                                        Command="{Binding StopRecordingCommand}"
                                        Padding="10,5" FontSize="14"
                                        ToolTip="{Binding L[UI.StopRecord]}"/>
                                <TextBlock VerticalAlignment="Center" Margin="6,0"
                                           Foreground="{StaticResource BrandOrange}"
                                           FontFamily="Consolas" FontSize="13">
                                    <Run Text="{Binding RecordingDuration, Mode=OneWay}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding RecordingFrameCount, Mode=OneWay}"/><Run Text="f"/>
                                </TextBlock>
                            </StackPanel>
                            <Border Height="1" Background="#33FFFFFF" Margin="2,2,2,4"/>

                            <ListBox Height="90" ItemsSource="{Binding RecordedSessions}" SelectedItem="{Binding SelectedSession}"
                                     Background="{StaticResource SurfaceBg}" Foreground="{StaticResource TextPrimary}" BorderBrush="#33FFFFFF">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12">
                                            <Run Text="{Binding Name, Mode=OneWay}"/> <Run Text="{Binding Frames.Count, StringFormat='({0}f)', Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Button Content="{Binding L[Btn.SaveAVI]}" Style="{StaticResource BrandBtn}" Command="{Binding SaveSessionCommand}" Padding="8,4"/>
                                <Button Content="{Binding L[Btn.Delete]}" Style="{StaticResource BrandBtn}" Command="{Binding DeleteSessionCommand}" Padding="8,4"
                                        Background="#FF993333"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Sensor Info panel removed (按需求移除—感測器資訊在 HEADER 上方已顯示) -->

                    <!-- Diagnostic Panel (toggleable—診斷工具，獨立保留) -->
                    <GroupBox Header="{Binding L[Panel.Diagnostic]}" Visibility="{Binding ShowDiagPanel, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Button Content="{Binding L[Btn.Diagnostic]}" Style="{StaticResource BrandBtn}"
                                    Command="{Binding ToggleDiagCommand}" Margin="0,0,0,4" Padding="6,3"
                                    HorizontalAlignment="Right"/>
                            <TextBlock Foreground="{StaticResource AccentGreen}" FontSize="12" Margin="2">
                                <Run Text="{Binding L[Diag.Bytes]}"/><Run Text=" "/><Run Text="{Binding BytesReceivedCount, Mode=OneWay}"/>
                                <Run Text=" | "/><Run Text="{Binding L[Diag.Frames]}"/><Run Text=" "/><Run Text="{Binding TotalFrames, Mode=OneWay}"/>
                            </TextBlock>
                            <WrapPanel Margin="0,2">
                                <Button Content="{Binding L[Diag.Capture64K]}" Style="{StaticResource BrandBtn}" Command="{Binding CaptureRawCommand}" Padding="6,3"/>
                                <Button Content="{Binding L[Diag.ViewHex]}" Style="{StaticResource BrandBtn}" Command="{Binding ViewRawDataCommand}" Padding="6,3"/>
                                <Button Content="{Binding L[Diag.SaveBin]}" Style="{StaticResource BrandBtn}" Command="{Binding SaveRawDataCommand}" Padding="6,3"/>
                            </WrapPanel>
                            <TextBox Text="{Binding RawSerialData, Mode=OneWay}" IsReadOnly="True"
                                     Background="#FF151520" Foreground="#FF00FF00" FontFamily="Consolas" FontSize="8"
                                     Height="150" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     BorderBrush="#33FFFFFF" Margin="0,4,0,0"/>
                            <TextBox Text="{Binding DiagnosticLog, Mode=OneWay}" IsReadOnly="True"
                                     Background="#FF151520" Foreground="#FFFFFF99" FontFamily="Consolas" FontSize="9"
                                     Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     BorderBrush="#33FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="{StaticResource BrandDarkBlue}" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentGreen}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource BrandOrange}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Foreground="{StaticResource TextSecondary}" FontSize="10" VerticalAlignment="Center">
                    <Run Text="{Binding L[Footer.Copyright], Mode=OneWay}"/><Run Text=" | "/><Run Text="{Binding L[App.Version], Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
