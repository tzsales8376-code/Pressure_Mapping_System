<Window x:Class="PressureMappingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PressureMappingSystem.Controls"
        xmlns:vm="clr-namespace:PressureMappingSystem.ViewModels"
        Title="{Binding L[App.Title]}"
        Width="1500" Height="960"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app.ico"
        Background="#FF1E1E2E"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="BrandOrange" Color="#FFED7D31"/>
        <SolidColorBrush x:Key="BrandBlue" Color="#FF2B5797"/>
        <SolidColorBrush x:Key="BrandDarkBlue" Color="#FF1B3A5C"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FF252536"/>
        <SolidColorBrush x:Key="SurfaceBg" Color="#FF2D2D40"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE0E0E8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9898A8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFE53935"/>

        <Style x:Key="BrandBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RecordBtn" TargetType="Button" BasedOn="{StaticResource BrandBtn}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="ToolBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandDarkBlue}" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Resources/app.ico" Width="28" Height="28" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="TRANZX" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandOrange}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding L[App.Subtitle]}" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="4,0,0,2"/>
                    <TextBlock Text="{Binding L[App.Version]}" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                </StackPanel>

                <!-- Language + Device Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DetectedDeviceInfo}" Foreground="{StaticResource AccentGreen}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding L[UI.Language]}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="120" SelectedIndex="0" SelectionChanged="LanguageCombo_SelectionChanged" FontSize="11">
                        <ComboBoxItem Content="繁體中文"/>
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="日本語"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" Padding="6,4">
            <WrapPanel>
                <!-- Connection -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="{Binding L[UI.COM]}" VerticalAlignment="Center" Margin="4,0"/>
                    <ComboBox Width="85" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" Margin="2,0"/>
                    <Button Content="&#x27F3;" Style="{StaticResource BrandBtn}" Command="{Binding ScanDevicesCommand}" ToolTip="{Binding L[Toolbar.Refresh]}" Padding="6,4"/>
                    <Button Content="{Binding L[UI.Connect]}" Style="{StaticResource BrandBtn}" Command="{Binding ConnectCommand}"/>
                    <Button Content="{Binding L[UI.Disconnect]}" Style="{StaticResource BrandBtn}" Command="{Binding DisconnectCommand}"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Measurement Control -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <Button Content="{Binding L[UI.StartMeasure]}" Style="{StaticResource BrandBtn}" Command="{Binding StartMeasurementCommand}" Background="{StaticResource AccentGreen}" FontWeight="Bold"/>
                    <Button Content="{Binding L[UI.StopMeasure]}" Style="{StaticResource BrandBtn}" Command="{Binding StopMeasurementCommand}" Background="{StaticResource AccentRed}" FontWeight="Bold"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Simulation -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <ComboBox Width="105" SelectedIndex="1" Margin="2,0" SelectionChanged="SimModeCombo_SelectionChanged" FontSize="11">
                        <ComboBoxItem Content="{Binding L[SimMode.StaticCenter]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.MovingPressure]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.PulsingPressure]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.MultiPoint]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.FullSurface]}"/>
                        <ComboBoxItem Content="{Binding L[SimMode.RandomNoise]}"/>
                    </ComboBox>
                    <Button Content="{Binding L[UI.StartSim]}" Style="{StaticResource BrandBtn}" Command="{Binding StartSimulationCommand}"/>
                    <Button Content="{Binding L[UI.StopSim]}" Style="{StaticResource BrandBtn}" Command="{Binding StopSimulationCommand}" Padding="8,6"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- Zero + Calibration + Settings -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <ToggleButton Content="{Binding L[UI.Zero]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding IsZeroEnabled}" ToolTip="{Binding L[UI.Zero]}"/>
                    <ComboBox Width="130" Margin="4,0,2,0"
                              ItemsSource="{Binding AvailableCalProfiles}"
                              SelectedItem="{Binding SelectedCalProfile}"
                              DisplayMemberPath="Name"
                              ToolTip="{Binding L[Toolbar.CalRecipe]}"
                              FontSize="11"/>
                    <Button Content="{Binding L[UI.Calibration]}" Style="{StaticResource BrandBtn}" Command="{Binding OpenCalibrationCommand}" ToolTip="{Binding L[UI.Calibration]}"/>
                    <Button Content="&#x2699;" Style="{StaticResource BrandBtn}" Command="{Binding OpenSettingsCommand}" ToolTip="{Binding L[UI.Settings]}" FontSize="16" Padding="6,2"/>
                </StackPanel>
                <Border Width="1" Background="#33FFFFFF" Margin="4,2"/>

                <!-- View Mode -->
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <Button Content="{Binding L[UI.2DHeat]}" Style="{StaticResource BrandBtn}" Command="{Binding SetHeatmapModeCommand}" Padding="8,6"/>
                    <Button Content="{Binding L[UI.2DContour]}" Style="{StaticResource BrandBtn}" Command="{Binding SetContourModeCommand}" Padding="8,6"/>
                    <Button Content="{Binding L[UI.3D]}" Style="{StaticResource BrandBtn}" Click="Show3D_Click" Padding="8,6"/>
                    <Button Content="{Binding L[UI.Trend]}" Style="{StaticResource BrandBtn}" Click="ShowTrend_Click" Padding="8,6"/>
                    <ToggleButton Content="{Binding L[UI.Peak]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowPeakMap}"/>
                    <ToggleButton Content="{Binding L[UI.Grid]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowGrid}"/>
                    <ToggleButton Content="{Binding L[UI.Values]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowValues}"/>
                    <ToggleButton Content="{Binding L[UI.CoPLabel]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowCoP}"/>
                    <ToggleButton Content="{Binding L[UI.Legend]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowLegend}"/>

                    <!-- Interpolation Level -->
                    <Border Width="1" Background="#33FFFFFF" Margin="6,2"/>
                    <TextBlock Text="{Binding L[UI.Interp]}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="4,0,2,0"/>
                    <ComboBox x:Name="InterpCombo" Width="80" SelectedIndex="0" SelectionChanged="InterpCombo_SelectionChanged" FontSize="11" VerticalAlignment="Center">
                        <ComboBoxItem Content="1×1"/>
                        <ComboBoxItem Content="3×3"/>
                        <ComboBoxItem Content="5×5"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Visualization Tabs -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" x:Name="ViewTabControl" SelectedIndex="{Binding SelectedViewTab}"
                            Background="{StaticResource SurfaceBg}" BorderBrush="#33FFFFFF">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
                            <Setter Property="Padding" Value="12,6"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- Tab 0: 2D Heatmap -->
                    <TabItem Header="{Binding L[Tab.Heatmap]}">
                        <controls:HeatmapControl x:Name="HeatmapView"
                            PressureData="{Binding CurrentPressureData}"
                            FrameInfo="{Binding CurrentFrame}"
                            DisplayMode="{Binding DisplayMode}"
                            ShowGrid="{Binding ShowGrid}"
                            ShowValues="{Binding ShowValues}"
                            ShowCoP="{Binding ShowCoP}"
                            ShowLegend="{Binding ShowLegend}"
                            ContourLevels="{Binding ContourLevels}"
                            ColorScaleMax="{Binding ColorScaleMaxGrams}"
                            IsPaused="{Binding IsFrozen}"
                            InterpolationLevel="{Binding InterpolationLevel}"/>
                    </TabItem>

                    <!-- Tab 1: 3D Surface -->
                    <TabItem Header="{Binding L[Tab.3DSurface]}">
                        <controls:Surface3DControl x:Name="Surface3DView"
                            PressureData="{Binding CurrentPressureData}"
                            ColorScaleMax="{Binding ColorScaleMaxGrams}"/>
                    </TabItem>

                    <!-- Tab 2: Trend Chart -->
                    <TabItem Header="{Binding L[Tab.TrendChart]}">
                        <controls:TrendChartControl x:Name="TrendChartView"/>
                    </TabItem>
                </TabControl>

                <!-- Recording / Playback Bar -->
                <Border Grid.Row="1" Background="{StaticResource PanelBg}" CornerRadius="4" Margin="2" Padding="8,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Recording -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                            <Button Content="{Binding L[UI.Record]}" Style="{StaticResource RecordBtn}" Command="{Binding StartRecordingCommand}" FontWeight="Bold" Padding="10,4"/>
                            <Button Content="⏹" Style="{StaticResource BrandBtn}" Command="{Binding StopRecordingCommand}" Padding="8,4"/>
                            <Border Width="1" Background="#33FFFFFF" Margin="6,2"/>
                            <TextBlock VerticalAlignment="Center" Margin="4,0" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                <Run Text="{Binding RecordingDuration, Mode=OneWay}" Foreground="{StaticResource BrandOrange}"/>
                                <Run Text=" | "/> <Run Text="{Binding RecordingFrameCount, Mode=OneWay}"/> <Run Text="f"/>
                            </TextBlock>
                            <Border Width="1" Background="#33FFFFFF" Margin="6,2"/>
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AccentGreen}" FontSize="11">
                                <Run Text="FPS:"/> <Run Text="{Binding CurrentFps, StringFormat=F1, Mode=OneWay}"/>
                                <Run Text=" | #"/> <Run Text="{Binding TotalFrames, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Pause + Capture -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <ToggleButton Content="{Binding L[UI.Freeze]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding IsFrozen}" ToolTip="{Binding L[UI.Freeze]}" Padding="10,4" FontSize="13"/>
                            <Button Content="{Binding L[UI.Capture]}" Style="{StaticResource BrandBtn}" Command="{Binding CaptureFrameCommand}" ToolTip="{Binding L[UI.Capture]}" Padding="10,4" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ RIGHT PANEL ═══ -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4">

                    <!-- Statistics -->
                    <GroupBox Header="{Binding L[Panel.Stats]}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding L[Stats.PeakPressure]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{StaticResource BrandOrange}" FontWeight="Bold" FontSize="14" Margin="2">
                                <Run Text="{Binding PeakPressure, StringFormat=F1, Mode=OneWay}"/><Run Text=" g"/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding L[Stats.TotalForce]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="2"><Run Text="{Binding TotalForce, StringFormat=F1, Mode=OneWay}"/><Run Text=" g"/></TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding L[Stats.AvgPressure]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="2"><Run Text="{Binding AveragePressure, StringFormat=F1, Mode=OneWay}"/><Run Text=" g"/></TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding L[Stats.ActivePoints]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="2"><Run Text="{Binding ActivePoints, Mode=OneWay}"/><Run Text=" / 1600"/></TextBlock>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding L[Stats.ContactArea]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="2"><Run Text="{Binding ContactArea, StringFormat=F2, Mode=OneWay}"/><Run Text=" mm²"/></TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding L[Stats.CoP]}" Foreground="{StaticResource TextSecondary}" Margin="2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="2">
                                <Run Text="("/><Run Text="{Binding CoPX, StringFormat=F1, Mode=OneWay}"/>
                                <Run Text=","/><Run Text="{Binding CoPY, StringFormat=F1, Mode=OneWay}"/><Run Text=") mm"/>
                            </TextBlock>
                            <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="2,4,2,0" Foreground="{StaticResource TextSecondary}" FontSize="10"
                                       Text="{Binding HoverInfo, Mode=OneWay}" TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>

                    <!-- PEAK -->
                    <GroupBox Header="{Binding L[Panel.Peak]}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="16" Margin="2">
                                <Run Text="{Binding SessionPeakPressure, StringFormat=F1, Mode=OneWay}"/><Run Text=" g"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="2">
                                <Run Text="@Row "/><Run Text="{Binding SessionPeakRow, Mode=OneWay}"/>
                                <Run Text=" Col "/><Run Text="{Binding SessionPeakCol, Mode=OneWay}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="{Binding L[Btn.Reset]}" Style="{StaticResource BrandBtn}" Command="{Binding ResetPeakCommand}" Padding="8,4"/>
                                <ToggleButton Content="{Binding L[Btn.PeakMap]}" Style="{StaticResource ToolBtn}" IsChecked="{Binding ShowPeakMap}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- ROI Analysis -->
                    <GroupBox Header="{Binding L[Panel.ROI]}">
                        <StackPanel>
                            <WrapPanel>
                                <Button Content="{Binding L[Btn.Rect]}" Style="{StaticResource BrandBtn}" Command="{Binding AddRoiRectCommand}" Padding="8,4"/>
                                <Button Content="{Binding L[Btn.Ellipse]}" Style="{StaticResource BrandBtn}" Command="{Binding AddRoiEllipseCommand}" Padding="8,4"/>
                                <Button Content="{Binding L[Btn.Clear]}" Style="{StaticResource BrandBtn}" Command="{Binding ClearRoiCommand}" Padding="8,4"/>
                            </WrapPanel>
                            <TextBlock Text="{Binding RoiStatsText, Mode=OneWay}" Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="2,4,2,0"/>
                            <ItemsControl ItemsSource="{Binding RoiRegions}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="10" Margin="2,1">
                                            <Run Text="■" Foreground="{Binding Color}"/>
                                            <Run Text="{Binding Name, Mode=OneWay}" Foreground="{StaticResource TextPrimary}"/>
                                            <Run Text="{Binding Type, Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <!-- Export -->
                    <GroupBox Header="{Binding L[Panel.Export]}">
                        <WrapPanel>
                            <Button Content="{Binding L[Btn.CSV]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportCsvCommand}" Width="60"/>
                            <Button Content="{Binding L[Btn.JPG]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportJpgCommand}" Width="60"/>
                            <Button Content="{Binding L[Btn.PDFReport]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportPdfCommand}" Width="90"/>
                            <Button Content="{Binding L[Btn.CalReport]}" Style="{StaticResource BrandBtn}" Command="{Binding ExportCalReportCommand}" Width="90"/>
                            <Button Content="{Binding L[Btn.OpenFolder]}" Style="{StaticResource BrandBtn}" Command="{Binding OpenExportFolderCommand}" Width="110" Margin="2"/>
                        </WrapPanel>
                    </GroupBox>

                    <!-- Session Management -->
                    <GroupBox Header="{Binding L[Panel.Recording]}">
                        <StackPanel>
                            <ListBox Height="90" ItemsSource="{Binding RecordedSessions}" SelectedItem="{Binding SelectedSession}"
                                     Background="{StaticResource SurfaceBg}" Foreground="{StaticResource TextPrimary}" BorderBrush="#33FFFFFF">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11">
                                            <Run Text="{Binding Name, Mode=OneWay}"/> <Run Text="{Binding Frames.Count, StringFormat='({0}f)', Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Button Content="{Binding L[Btn.SaveAVI]}" Style="{StaticResource BrandBtn}" Command="{Binding SaveSessionCommand}" Padding="8,4"/>
                                <Button Content="{Binding L[Btn.Delete]}" Style="{StaticResource BrandBtn}" Command="{Binding DeleteSessionCommand}" Padding="8,4"
                                        Background="#FF993333"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Sensor Info -->
                    <GroupBox Header="{Binding L[Panel.Sensor]}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10" TextWrapping="Wrap" LineHeight="16">
                                <Run FontWeight="Bold">FS-ARR-40X40-S20</Run><LineBreak/>
                                <Run>40×40 (1600pts) | 0.5mm pitch</Run><LineBreak/>
                                <Run>5g~1000g | 0.2KΩ~500KΩ</Run><LineBreak/>
                                <Run>USB 115200,8N1 | &lt;10μs</Run>
                            </TextBlock>
                            <Button Content="{Binding L[Btn.Diagnostic]}" Style="{StaticResource BrandBtn}" Command="{Binding ToggleDiagCommand}" Margin="0,4,0,0" Padding="6,3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Diagnostic Panel (toggleable) -->
                    <GroupBox Header="{Binding L[Panel.Diagnostic]}" Visibility="{Binding ShowDiagPanel, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource AccentGreen}" FontSize="11" Margin="2">
                                <Run Text="{Binding L[Diag.Bytes]}"/><Run Text=" "/><Run Text="{Binding BytesReceivedCount, Mode=OneWay}"/>
                                <Run Text=" | "/><Run Text="{Binding L[Diag.Frames]}"/><Run Text=" "/><Run Text="{Binding TotalFrames, Mode=OneWay}"/>
                            </TextBlock>
                            <WrapPanel Margin="0,2">
                                <Button Content="{Binding L[Diag.Capture64K]}" Style="{StaticResource BrandBtn}" Command="{Binding CaptureRawCommand}" Padding="6,3"/>
                                <Button Content="{Binding L[Diag.ViewHex]}" Style="{StaticResource BrandBtn}" Command="{Binding ViewRawDataCommand}" Padding="6,3"/>
                                <Button Content="{Binding L[Diag.SaveBin]}" Style="{StaticResource BrandBtn}" Command="{Binding SaveRawDataCommand}" Padding="6,3"/>
                            </WrapPanel>
                            <TextBox Text="{Binding RawSerialData, Mode=OneWay}" IsReadOnly="True"
                                     Background="#FF151520" Foreground="#FF00FF00" FontFamily="Consolas" FontSize="8"
                                     Height="150" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     BorderBrush="#33FFFFFF" Margin="0,4,0,0"/>
                            <TextBox Text="{Binding DiagnosticLog, Mode=OneWay}" IsReadOnly="True"
                                     Background="#FF151520" Foreground="#FFFFFF99" FontFamily="Consolas" FontSize="9"
                                     Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     BorderBrush="#33FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="{StaticResource BrandDarkBlue}" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentGreen}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource BrandOrange}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Foreground="{StaticResource TextSecondary}" FontSize="10" VerticalAlignment="Center">
                    <Run Text="{Binding L[Footer.Copyright], Mode=OneWay}"/><Run Text=" | "/><Run Text="{Binding L[App.Version], Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
