<Window x:Class="PressureMappingSystem.Controls.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匯出影片" Width="420" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#FF1E1E2E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0"
                   Text="正在匯出影片..."
                   Foreground="#FFCCCCCC" FontSize="14" Margin="0,0,0,12"/>

        <ProgressBar x:Name="ProgressBar" Grid.Row="1"
                     Height="24" Minimum="0" Maximum="100" Value="0"
                     Foreground="#FF0078D4" Background="#FF2D2D3D"/>

        <TextBlock x:Name="PercentText" Grid.Row="2"
                   Text="0%"
                   Foreground="#FF888888" FontSize="12" Margin="0,8,0,0"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
