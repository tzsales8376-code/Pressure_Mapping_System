<UserControl x:Class="PressureMappingSystem.Controls.Surface3DControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 3D Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <TextBlock Text="3D Surface View" Foreground="#FFED7D31" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="4,0"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,2"/>
            <TextBlock Text="Height Scale:" Foreground="#FFE0E0E8" VerticalAlignment="Center" Margin="4,0"/>
            <Slider x:Name="HeightSlider" Width="100" Minimum="0.1" Maximum="5.0" Value="1.0"
                    VerticalAlignment="Center" ValueChanged="HeightSlider_ValueChanged"/>
            <TextBlock Text="{Binding ElementName=HeightSlider, Path=Value, StringFormat='{}{0:F1}x'}"
                       Foreground="#FF9898A8" VerticalAlignment="Center" Margin="4,0" Width="32"/>
            <CheckBox x:Name="WireframeCheck" Content="Wireframe" Foreground="#FFE0E0E8"
                      VerticalAlignment="Center" Margin="8,0" Checked="OnRenderOptionChanged" Unchecked="OnRenderOptionChanged"/>
            <Button Content="Reset View" Margin="8,0" Padding="8,3" Click="ResetView_Click"
                    Background="#FF2B5797" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <!-- 3D Viewport + Color Legend -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FF1E1E2E" ClipToBounds="True">
            <Viewport3D x:Name="Viewport3D"
                         MouseLeftButtonDown="Viewport3D_MouseLeftButtonDown"
                         MouseLeftButtonUp="Viewport3D_MouseLeftButtonUp"
                         MouseRightButtonDown="Viewport3D_MouseRightButtonDown"
                         MouseRightButtonUp="Viewport3D_MouseRightButtonUp"
                         MouseMove="Viewport3D_MouseMove"
                         MouseWheel="Viewport3D_MouseWheel">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="Camera3D"
                                       Position="25,25,35"
                                       LookDirection="-25,-25,-35"
                                       UpDirection="0,0,1"
                                       FieldOfView="45"/>
                </Viewport3D.Camera>

                <!-- Ambient Light -->
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <AmbientLight Color="#FF505050"/>
                    </ModelVisual3D.Content>
                </ModelVisual3D>

                <!-- Directional Lights -->
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <DirectionalLight Color="#FFFFFFFF" Direction="-1,-1,-1"/>
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <DirectionalLight Color="#FF808080" Direction="1,1,-0.5"/>
                    </ModelVisual3D.Content>
                </ModelVisual3D>

                <!-- Surface Model (populated in code-behind) -->
                <ModelVisual3D x:Name="SurfaceModel"/>

                <!-- Base Grid (populated in code-behind) -->
                <ModelVisual3D x:Name="GridModel"/>
            </Viewport3D>
        </Border>

            <!-- Color Legend for 3D -->
            <Border Grid.Column="1" Background="#FF1E1E2E" Padding="4,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Pressure&#x0a;(gf)" Foreground="#FFB0B0B0" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Canvas x:Name="LegendCanvas" Grid.Row="1"/>
                    <TextBlock Grid.Row="2" x:Name="LegendRangeText" Text="0 - 1000" Foreground="#FF808080" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
