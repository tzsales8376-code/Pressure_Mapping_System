<Window x:Class="PressureMappingSystem.Controls.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="多點校正 — Multi-point Calibration"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E">
    <Window.Resources>
        <SolidColorBrush x:Key="BrandOrange" Color="#FFED7D31"/>
        <SolidColorBrush x:Key="BrandBlue" Color="#FF2B5797"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FF252536"/>
        <SolidColorBrush x:Key="FieldBg" Color="#FF2D2D3D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE0E0E8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9898A8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFE53935"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#FFFFAA44"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
        </Style>
        <Style x:Key="AmberBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="{StaticResource AccentAmber}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
        </Style>
        <Style x:Key="GrayBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#FF555566"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandOrange}">
                <Run Text="多點校正"/>
                <Run Text="  ·  Raw Sum → Weight  Calibration" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
            </TextBlock>
            <TextBlock Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap">
                <Run Text="流程：① 放已知砝碼 ② 等讀數穩定 ③ 按「擷取」記錄整片總和 ④ 累積多個不同重量 ⑤ 選擬合方法 ⑥ 按「計算擬合」檢視殘差 ⑦ 儲存"/>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="擬合方法：" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" x:Name="FitMethodCombo" Width="260" SelectedIndex="1" FontSize="12">
                <ComboBoxItem Content="Linear — W = slope × raw + intercept"/>
                <ComboBoxItem Content="PowerLaw — W = scale × raw^exp  (建議)"/>
            </ComboBox>
            <TextBlock Grid.Column="3" Text="砝碼(g)：" Margin="20,0,6,0"/>
            <TextBox Grid.Column="4" x:Name="NewWeightBox" Width="100" Text="1000"/>
            <Button Grid.Column="5" Content="＋ 新增空白列" Style="{StaticResource GrayBtn}" Click="AddRow_Click" Margin="10,0,0,0"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{StaticResource BrandBlue}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="✓" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="標籤" HorizontalAlignment="Center" FontWeight="Bold" Margin="4,0"/>
                    <TextBlock Grid.Column="3" Text="砝碼 (g)" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="Raw Sum" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="5" Text="Active" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="6" Text="擬合 (g)" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="7" Text="殘差 %" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="8" Text="動作" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource PanelBg}">
                    <StackPanel x:Name="RowsPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource PanelBg}" CornerRadius="3" Margin="0,6,0,0" Padding="10,6">
            <StackPanel>
                <TextBlock x:Name="FitResultText" FontFamily="Consolas" FontSize="13"
                           Foreground="{StaticResource AccentGreen}" Text="(尚未擬合)"/>
                <TextBlock x:Name="FitDetailText" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" x:Name="StatusText" Text="請先連接感測器並完成歸零"
                   Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="從檔案載入" Style="{StaticResource GrayBtn}" Click="LoadFile_Click"/>
                <Button Content="清除全部" Style="{StaticResource GrayBtn}" Click="ClearAll_Click"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="計算擬合" Style="{StaticResource AmberBtn}" FontWeight="Bold" Click="Calculate_Click"/>
                <Button Content="套用到主程式" Style="{StaticResource GreenBtn}" FontWeight="Bold" Click="Apply_Click"/>
                <Button Content="💾 儲存" Style="{StaticResource Btn}" FontWeight="Bold" Click="Save_Click"/>
                <Button Content="關閉" Style="{StaticResource GrayBtn}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
