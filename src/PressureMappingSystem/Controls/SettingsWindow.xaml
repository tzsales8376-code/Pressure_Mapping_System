<Window x:Class="PressureMappingSystem.Controls.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L[Settings.Title]}" Width="470" Height="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E2E">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFED7D31"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding L[Settings.Title]}" FontSize="18" FontWeight="Bold"
                       Foreground="#FFED7D31" Margin="0,0,0,16"/>

            <!-- ━━━ 濾波器模式 ━━━ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="{Binding L[Settings.FilterMode]}"/>
            <TextBlock Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="{Binding L[Settings.FilterModeDesc]}"/>

            <ComboBox x:Name="FilterModeCombo" Height="32" FontSize="13" Margin="0,0,0,8"
                      SelectionChanged="FilterModeCombo_SelectionChanged">
                <ComboBoxItem Content="{Binding L[Settings.LegacyLabel]}"/>
                <ComboBoxItem Content="{Binding L[Settings.TcfLabel]}"/>
            </ComboBox>

            <!-- TCF 進階參數（只有選 TCF 時才顯示） -->
            <StackPanel x:Name="TcfParamsPanel" Margin="0,4,0,0" Visibility="Collapsed">
                <TextBlock Style="{StaticResource LabelStyle}" Margin="0,4,0,6">
                    <Run Text="{Binding L[Settings.Response], Mode=OneWay}"/>
                    <Run Text=" "/>
                    <Run x:Name="TcfResponseText" Text="80" Foreground="#FFED7D31" FontWeight="Bold"/>
                    <Run Text=" ms"/>
                </TextBlock>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="30ms" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="TcfResponseSlider" Grid.Column="1"
                            Minimum="30" Maximum="500" Value="80"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="TcfResponseSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" Text="500ms" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="{Binding L[Settings.ResponseHint]}"/>

                <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,6">
                    <Run Text="{Binding L[Settings.NoiseSup], Mode=OneWay}"/>
                    <Run Text=" "/>
                    <Run x:Name="TcfNoiseSupText" Text="50" Foreground="#FFED7D31" FontWeight="Bold"/>
                </TextBlock>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="0" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="TcfNoiseSupSlider" Grid.Column="1"
                            Minimum="0" Maximum="100" Value="50"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="TcfNoiseSupSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" Text="100" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                           Text="{Binding L[Settings.NoiseSupHint]}"/>
            </StackPanel>

            <Border Height="1" Background="#33FFFFFF" Margin="0,4,0,12"/>

            <!-- ━━━ Display Range ━━━ -->
            <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,6">
                <Run Text="{Binding L[Settings.DisplayRange], Mode=OneWay}"/>
                <Run Text=" "/>
                <Run x:Name="ThresholdValueText" Text="1600" Foreground="#FFED7D31" FontWeight="Bold"/>
                <Run Text=" kg"/>
            </TextBlock>
            <TextBlock x:Name="PerPointText" Foreground="#FF9898A8" FontSize="11" Margin="0,0,0,6"
                       Text="(Per point: 1000.0 g)"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="10 kg" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="ThresholdSlider" Grid.Column="1"
                        Minimum="10" Maximum="1600" Value="1600"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        ValueChanged="ThresholdSlider_ValueChanged"/>
                <TextBlock Grid.Column="2" Text="1600 kg" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,16"
                       Text="{Binding L[Settings.DisplayRangeHint]}"/>

            <!-- Noise Floor Slider (最低感測門檻) -->
            <Border Height="1" Background="#33FFFFFF" Margin="0,8,0,12"/>

            <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,6">
                <Run Text="{Binding L[Settings.MinThreshold], Mode=OneWay}"/>
                <Run Text=" "/>
                <Run x:Name="NoiseFloorValueText" Text="5" Foreground="#FFED7D31" FontWeight="Bold"/>
                <Run Text=" g"/>
            </TextBlock>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="5 g" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="NoiseFloorSlider" Grid.Column="1"
                        Minimum="5" Maximum="100" Value="5"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="NoiseFloorSlider_ValueChanged"/>
                <TextBlock Grid.Column="2" Text="100 g" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,16"
                       Text="{Binding L[Settings.MinThresholdHint]}"/>

            <!-- Signal Purity Slider (訊號純淨度) -->
            <Border Height="1" Background="#33FFFFFF" Margin="0,8,0,12"/>

            <TextBlock Style="{StaticResource LabelStyle}" Margin="0,0,0,6">
                <Run Text="{Binding L[Settings.SignalPurity], Mode=OneWay}"/>
                <Run Text=" D"/>
                <Run x:Name="NoiseFilterDLevelText" Text="—" Foreground="#FFED7D31" FontWeight="Bold"/>
                <Run Text="  ["/>
                <Run x:Name="NoiseFilterValueText" Text="0" Foreground="#FFED7D31" FontWeight="Bold"/>
                <Run Text=" %]"/>
            </TextBlock>
            <TextBlock x:Name="NoiseFilterDescText" Foreground="#FF9898A8" FontSize="11" Margin="0,0,0,6"
                       Text="(未啟用)"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="OFF" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="NoiseFilterSlider" Grid.Column="1"
                        Minimum="0" Maximum="50" Value="0"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="NoiseFilterSlider_ValueChanged"/>
                <TextBlock Grid.Column="2" Text="D50" Foreground="#FF9898A8" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock x:Name="PuritySliderHint" Foreground="#FF9898A8" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,16"
                       Text="{Binding L[Settings.PurityFullHint]}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="{Binding L[Settings.Reset]}" Padding="12,6" Margin="4"
                        Background="#FF444444" Foreground="White" BorderThickness="0"
                        Click="Reset_Click"/>
                <Button Content="💾 儲存設定" Padding="12,6" Margin="4"
                        Background="#FF4CAF50" Foreground="White" BorderThickness="0"
                        FontWeight="Bold"
                        Click="Save_Click"/>
                <Button Content="{Binding L[Settings.Close]}" Padding="12,6" Margin="4"
                        Background="#FF2B5797" Foreground="White" BorderThickness="0"
                        Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
