<Window x:Class="PressureMappingSystem.Comparison.ComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="clr-namespace:PressureMappingSystem.Controls"
        xmlns:cc="clr-namespace:PressureMappingSystem.Comparison.Controls"
        Title="壓力圖比對 / Reference vs DUT"
        Width="1400" Height="920"
        MinWidth="1100" MinHeight="700"
        Background="#FF1E1E2E"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#FF252536"/>
        <SolidColorBrush x:Key="FieldBg" Color="#FF2D2D3D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE0E0E8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9898A8"/>
        <SolidColorBrush x:Key="BrandOrange" Color="#FFED7D31"/>
        <SolidColorBrush x:Key="BrandBlue" Color="#FF2B5797"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFE53935"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header: title + config readout -->
            <RowDefinition Height="*"/>     <!-- 三張圖 -->
            <RowDefinition Height="Auto"/>  <!-- ScoreCard + Metrics -->
            <RowDefinition Height="Auto"/>  <!-- bottom buttons -->
        </Grid.RowDefinitions>

        <!-- Header: 模式說明 + 設定檔來源 -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" Padding="14,10" CornerRadius="3" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="基準-待測 (Reference vs DUT)" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource BrandOrange}"/>
                    <TextBlock Text="A = 黃金樣品 (Reference)，B = 待測 (DUT)。系統以業界標準四分項加權評分。"
                               FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock x:Name="ConfigSourceText" Text=""
                               FontSize="10" Foreground="{StaticResource TextSecondary}"
                               TextAlignment="Right"/>
                    <Button Content="📂 開啟設定檔資料夾" Style="{StaticResource Btn}"
                            Click="OpenConfigFolder_Click"
                            Padding="8,3" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 三張熱力圖 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- A = Reference -->
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="3" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="A — 基準 / Reference" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource BrandOrange}" Margin="8,6"/>
                    <hc:HeatmapControl Grid.Row="1" x:Name="HeatmapA" Margin="6"
                                       MinHeight="350" VerticalAlignment="Stretch"/>
                    <TextBlock Grid.Row="2" x:Name="InfoTextA" Margin="8,4,8,8"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </Border>

            <!-- B = DUT -->
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="3" Margin="2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="B — 待測 / DUT" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource BrandOrange}" Margin="8,6"/>
                    <hc:HeatmapControl Grid.Row="1" x:Name="HeatmapB" Margin="6"
                                       MinHeight="350" VerticalAlignment="Stretch"/>
                    <TextBlock Grid.Row="2" x:Name="InfoTextB" Margin="8,4,8,8"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </Border>

            <!-- 絕對差 -->
            <Border Grid.Column="2" Background="{StaticResource PanelBg}" CornerRadius="3" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="絕對差 |A − B|" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource BrandOrange}" Margin="8,6"/>
                    <hc:HeatmapControl Grid.Row="1" x:Name="HeatmapAbsDiff" Margin="6"
                                       MinHeight="350" VerticalAlignment="Stretch"/>
                    <TextBlock Grid.Row="2" x:Name="DiffLegend" Margin="8,4,8,8"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ScoreCard + 摘要 -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- ScoreCard 主體（佔大部分） -->
            <cc:ScoreCardControl Grid.Column="0" x:Name="ScoreCard"/>

            <!-- 右側：摘要差 + Warnings -->
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="3"
                    Padding="14,10" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="摘要差 / Summary Delta" FontWeight="Bold"
                                   Foreground="{StaticResource BrandOrange}"/>
                        <TextBlock x:Name="MetricPeakText" FontFamily="Consolas" Margin="0,4,0,0"/>
                        <TextBlock x:Name="MetricTotalText" FontFamily="Consolas"/>
                        <TextBlock x:Name="MetricActiveText" FontFamily="Consolas"/>
                        <TextBlock x:Name="MetricCopText" FontFamily="Consolas"/>
                        <TextBlock x:Name="MetricMaeText" FontFamily="Consolas"/>

                        <!-- Warnings -->
                        <StackPanel x:Name="WarningPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock Text="提醒 / Warnings" FontWeight="Bold"
                                       Foreground="{StaticResource AccentRed}"/>
                            <ItemsControl x:Name="WarningList" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{StaticResource AccentRed}"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部按鈕 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="💾 匯出比對報告" Style="{StaticResource Btn}" Click="SaveReport_Click"/>
            <Button Content="關閉" Style="{StaticResource Btn}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
